
LITESTAR_APP=SimplyTransport.app:create_app
SECRET_KEY=secret
DEBUG=true
ENVIRONMENT=DEV
LOG_LEVEL=INFO

# Database
DB_URL=postgresql+asyncpg://example:example@localhost:5432/example
DB_URL_SYNC=postgresql+psycopg2://example:example@localhost:5432/example
DB_ECHO=false
TIMESCALE_URL=postgresql+asyncpg://example:example@localhost:5433/example

# Postgres Docker
POSTGRES_DB=example
POSTGRES_USER=example
POSTGRES_PASSWORD=example

# Timescale Docker
TIMESCALE_DB=example
TIMESCALE_USER=example
TIMESCALE_PASSWORD=example

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=example

# OpenTelemetry (app → collector). Default matches collector on localhost.
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# Collector → Aspire OTLP/gRPC (Aspire 9.x uses 18889 inside the container)
ASPIRE_OTLP_ENDPOINT=aspire-dashboard:18889

# GTFS
GTFS_TFI_REALTIME_URL=example
GTFS_TFI_API_KEY_1=example
GTFS_TFI_API_KEY_2=example
# Must match the folder name used with importgtfs (e.g. TFI for ./gtfs_data/TFI/ or tests/gtfs_test_data/TFI/)
GTFS_TFI_DATASET=TFI